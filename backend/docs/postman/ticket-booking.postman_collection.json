    {
      "name": "Admin Events",
      "item": [
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.event?.id) pm.environment.set('eventId', json.data.event.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Coldplay Concert\",\n  \"description\": \"Live music concert event\",\n  \"location\": \"Ahmedabad Stadium\",\n  \"startDate\": \"2026-08-10T18:00:00.000Z\",\n  \"endDate\": \"2026-08-10T22:00:00.000Z\",\n  \"seatPriceInPaise\": 50000,\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/events"
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Coldplay Concert Updated\",\n  \"status\": \"PUBLISHED\",\n  \"seatPriceInPaise\": 75000\n}"
            },
            "url": "{{baseUrl}}/api/admin/events/{{eventId}}"
          }
        },
        {
          "name": "Cancel Event",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "header": [],
            "url": "{{baseUrl}}/api/admin/events/{{eventId}}"
          }
        }
      ]
