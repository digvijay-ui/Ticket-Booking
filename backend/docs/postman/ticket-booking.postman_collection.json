    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events"
          }
        },
        {
          "name": "Get Event",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          }
        },
        {
          "name": "Get Event Seats",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const seats = json?.data?.seats || [];",
                  "if (seats[0]?.id) pm.environment.set('seatId1', seats[0].id);",
                  "if (seats[1]?.id) pm.environment.set('seatId2', seats[1].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventId}}/seats"
          }
        }
      ]
